{
  "name": "yunque",
  "version": "0.1.1",
  "private": true,
  "description": "Simple scaffolding tools.",
  "keywords": [
    "cli",
    "yunque"
  ],
  "homepage": "https://github.com/yunquejs/yunque#readme",
  "bugs": {
    "url": "https://github.com/yunquejs/yunque/issues"
  },
  "license": "MIT",
  "author": "君惜",
  "repository": {
    "type": "git",
    "url": "https://github.com/yunquejs/yunque.git"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks",
    "copyfiles": "node ./scripts/copyfiles.js",
    "test": "jest",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@yunquejs/fabric": "workspace:*",
    "@yunquejs/release": "workspace:*",
    "conventional-changelog-cli": "^4.1.0",
    "copyfiles": "^2.4.1",
    "lint-staged": "^15.2.2",
    "npm-run-all": "^4.1.5",
    "picocolors": "latest",
    "simple-git-hooks": "latest",
    "tsx": "latest",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --concurrent false",
    "commit-msg": "pnpm exec tsx scripts/verifyCommit.ts $1"
  },
  "lint-staged": {
    "*": [
      "vp check --fix --no-error-on-unmatched-pattern"
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "yunque": {
    "release": {
      "pkgName": "yunque",
      "pkgPrefix": "@yunquejs"
    }
  }
}
