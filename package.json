{
  "name": "yunque",
  "version": "0.1.1",
  "private": true,
  "description": "Simple scaffolding tools.",
  "keywords": [
    "cli",
    "yunque"
  ],
  "homepage": "https://github.com/yunquejs/yunque#readme",
  "bugs": {
    "url": "https://github.com/yunquejs/yunque/issues"
  },
  "license": "MIT",
  "author": "君惜",
  "repository": {
    "type": "git",
    "url": "https://github.com/yunquejs/yunque.git"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks",
    "copyfiles": "node ./scripts/copyfiles.js",
    "test": "jest",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@yunquejs/fabric": "workspace:*",
    "@yunquejs/release": "workspace:*",
    "conventional-changelog-cli": "^4.1.0",
    "copyfiles": "^2.4.1",
    "lint-staged": "^15.2.2",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "picocolors": "latest",
    "simple-git-hooks": "latest",
    "tsdown": "^0.21.7",
    "tsx": "latest",
    "typescript": "^4.9.5",
    "vitest": "^1.4.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --concurrent false",
    "commit-msg": "pnpm exec tsx scripts/verifyCommit.ts $1"
  },
  "lint-staged": {
    "*": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search",
        "typescript",
        "vite"
      ]
    }
  },
  "yunque": {
    "release": {
      "pkgName": "yunque",
      "pkgPrefix": "@yunquejs"
    }
  }
}
